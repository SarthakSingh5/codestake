{
  "manifest_version": 3,
  "name": "CodeStake - Hardcore LeetCode",
  "version": "1.0.0",
  "description": "Put real money on the line while practicing LeetCode.",
  "action": {},
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/problems/*"],
      "js": ["src/content.tsx"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/website-sync.ts"]
    }
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://codestake-zeta.vercel.app/*",
    "http://localhost/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://codestake-zeta.vercel.app/*",
      "http://localhost/*",
      "*://localhost/*"
    ]
  }
}
